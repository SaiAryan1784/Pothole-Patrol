# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-generate-with-python-secrets-module
ALLOWED_HOSTS=your-app.railway.app

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ─── Redis (Celery broker) ────────────────────────────────────────────────────
REDIS_URL=redis://default:password@redis.railway.internal:6379

# ─── Firebase ────────────────────────────────────────────────────────────────
# Railway/production: base64-encode your service account JSON and paste here
#   base64 -i firebase-credentials.json | tr -d '\n'
FIREBASE_CREDENTIALS_B64=

# Local dev only: path to the service account JSON file (leave blank on Railway)
FIREBASE_CREDENTIALS_JSON=

FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ─── GDAL / GEOS (macOS local dev only — leave blank on Railway/Docker) ───────
GDAL_LIBRARY_PATH=
GEOS_LIBRARY_PATH=

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-app.railway.app

# ─── ML ──────────────────────────────────────────────────────────────────────
ML_CONFIDENCE_THRESHOLD=0.70
ML_MODEL_PATH=

# ─── Google Maps (server-side geocoding for ward lookup) ─────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Civic Body Email Dispatch ───────────────────────────────────────────────
CIVIC_EMAIL_SENDER=reports@potholepatrol.in
GDA_WEBHOOK_URL=

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
